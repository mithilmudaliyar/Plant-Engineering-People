generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ContractOrderStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
  FORWARDED_TO_SENIOR
  CANNOT_BE_DONE
}

model Employee {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  role               String
  status             String   @default("active")
  passwordHash       String
  passwordSalt       String
  mustChangePassword Boolean  @default(true)
  // Permission to create/edit News posts and Job openings (kept flexible for
  // later per-person gating; defaults true so existing staff keep access).
  canManageContent   Boolean  @default(true)
  createdAt          DateTime @default(now())
  sessions           EmployeeSession[]
}

// Server-side staff sessions (same security model as applicant Session).
model EmployeeSession {
  id         Int      @id @default(autoincrement())
  tokenHash  String   @unique
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userAgent  String?
  ip         String?

  @@index([employeeId])
  @@index([expiresAt])
}

// ===== CAREERS / APPLICANT AUTH (password-based, server-side sessions) =====

model Applicant {
  id            Int              @id @default(autoincrement())
  name          String
  email         String           @unique
  phone         String?
  passwordHash  String
  passwordSalt  String
  emailVerified Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sessions      Session[]
  resetTokens   PasswordResetToken[]
  applications  JobApplication[]
  orders        ContractOrder[]
  quotes        SupplierQuote[]
}

// Server-side sessions. The cookie holds an opaque random token; only its
// SHA-256 hash is stored here so a DB leak cannot be used to forge sessions.
model Session {
  id          Int       @id @default(autoincrement())
  tokenHash   String    @unique
  applicantId Int
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  userAgent   String?
  ip          String?

  @@index([applicantId])
  @@index([expiresAt])
}

// Single-use password reset tokens (hash stored, not the raw token).
model PasswordResetToken {
  id          Int       @id @default(autoincrement())
  tokenHash   String    @unique
  applicantId Int
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([applicantId])
}

// ===== NEWS =====

model NewsPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  category    String   @default("Announcement")
  excerpt     String?
  body        String
  imageUrl    String?
  published   Boolean  @default(false)
  authorName  String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, publishedAt])
}

// ===== CAREERS / JOBS =====

model JobOpening {
  id             Int              @id @default(autoincrement())
  title          String
  department     String
  location       String
  employmentType String           @default("Full-time")
  experience     String?
  description    String
  responsibilities String?
  requirements   String?
  status         String           @default("OPEN")
  postedAt       DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   JobApplication[]

  @@index([status])
}

model JobApplication {
  id          Int        @id @default(autoincrement())
  jobId       Int
  job         JobOpening @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicantId Int
  applicant   Applicant  @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  coverLetter String?
  resumeUrl   String?
  status      String     @default("SUBMITTED")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([jobId, applicantId])
  @@index([applicantId])
}

model ContractOrder {
  id                 Int      @id @default(autoincrement())
  supplierId         Int
  supplier           Applicant @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  whatNeeded         String
  dimensions         String?
  blueprintAvailable Boolean  @default(false)
  briefDetails       String?
  isTicket           Boolean  @default(false)
  status             ContractOrderStatus @default(PENDING)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  employeeNotes      String?
  photos             OrderPhoto[]
}

model OrderPhoto {
  id          Int           @id @default(autoincrement())
  orderId     Int
  order       ContractOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photoUrl    String
  uploadedAt  DateTime      @default(now())
  isFlagged   Boolean       @default(false)
  flagComment String?
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model BuyOrderSheet {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  status      String         @default("OPEN")
  uploadedBy  String
  createdAt   DateTime       @default(now())
  items       BuyOrderItem[]
}

model BuyOrderItem {
  id            Int             @id @default(autoincrement())
  sheetId       Int
  sheet         BuyOrderSheet   @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  productName   String
  quantity      Float
  unit          String
  specification String?
  createdAt     DateTime        @default(now())
  quotes        SupplierQuote[]
}

model SupplierQuote {
  id           Int          @id @default(autoincrement())
  itemId       Int
  item         BuyOrderItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplierId   Int
  supplier     Applicant    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pricePerUnit Float
  notes        String?
  status       String       @default("PENDING")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([itemId, supplierId])
}
