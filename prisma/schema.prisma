generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContractOrderStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  COMPLETED
  REJECTED
  CANCELLED
  FORWARDED_TO_SENIOR
  CANNOT_BE_DONE
}

model Supplier {
  id            Int             @id @default(autoincrement())
  name          String?
  email         String          @unique
  passwordHash  String
  passwordSalt  String
  emailVerified Boolean         @default(false)
  createdAt     DateTime        @default(now())
  orders        ContractOrder[]
  quotes        SupplierQuote[]
}

model Employee {
  id                 Int      @id @default(autoincrement())
  name               String
  email              String   @unique
  role               String
  status             String   @default("active")
  passwordHash       String
  passwordSalt       String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
}

model ContractOrder {
  id                 Int      @id @default(autoincrement())
  supplierId         Int
  supplier           Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  whatNeeded         String
  dimensions         String?
  blueprintAvailable Boolean  @default(false)
  briefDetails       String?
  isTicket           Boolean  @default(false)
  status             ContractOrderStatus @default(PENDING)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  employeeNotes      String?
  photos             OrderPhoto[]
}

model OrderPhoto {
  id          Int           @id @default(autoincrement())
  orderId     Int
  order       ContractOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  photoUrl    String
  uploadedAt  DateTime      @default(now())
  isFlagged   Boolean       @default(false)
  flagComment String?
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model ContactInquiry {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model BuyOrderSheet {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  status      String         @default("OPEN")
  uploadedBy  String
  createdAt   DateTime       @default(now())
  items       BuyOrderItem[]
}

model BuyOrderItem {
  id            Int             @id @default(autoincrement())
  sheetId       Int
  sheet         BuyOrderSheet   @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  productName   String
  quantity      Float
  unit          String
  specification String?
  createdAt     DateTime        @default(now())
  quotes        SupplierQuote[]
}

model SupplierQuote {
  id           Int          @id @default(autoincrement())
  itemId       Int
  item         BuyOrderItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplierId   Int
  supplier     Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  pricePerUnit Float
  notes        String?
  status       String       @default("PENDING")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([itemId, supplierId])
}
